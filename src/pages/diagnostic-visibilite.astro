---
import { Icon } from "astro-icon/components";
import PageLayout from "../layouts/PageLayout.astro";
import QuoteButton from "../components/ui/QuoteButton.astro";

const abs = (p: string) => (Astro.site ? new URL(p, Astro.site).toString() : p);

const ORG_ID = `${abs("/")}#org-cpep`;
const WEBSITE_ID = `${abs("/")}#website-cpep`;
const WEBPAGE_ID = `${abs("/diagnostic-visibilite/")}#webpage-diagnostic-visibilite`;
const SERVICE_ID = `${abs("/diagnostic-visibilite/")}#service-diagnostic-visibilite`;

const auditPoints = [
  {
    icon: "lucide:search-check",
    title: "SEO technique",
    desc: "Balise title, meta description, H1, canonical, sitemap, robots.txt et premiers signaux d’indexation.",
  },
  {
    icon: "lucide:gauge",
    title: "Performance",
    desc: "Temps de chargement, poids de page, structure HTML et points qui peuvent ralentir l’expérience utilisateur.",
  },
  {
    icon: "lucide:smartphone",
    title: "Mobile & lisibilité",
    desc: "Présence du viewport, cohérence mobile, lisibilité et éléments importants pour les visiteurs sur smartphone.",
  },
  {
    icon: "lucide:image",
    title: "Images & contenus",
    desc: "Images sans texte alternatif, poids visuel, cohérence des titres et clarté du message principal.",
  },
  {
    icon: "lucide:map-pin",
    title: "Présence locale",
    desc: "Premiers signaux utiles pour les entreprises locales : cohérence, crédibilité et informations visibles.",
  },
  {
    icon: "lucide:shield-check",
    title: "Confiance",
    desc: "HTTPS, données structurées, réseaux sociaux, mentions utiles et éléments qui rassurent vos visiteurs.",
  },
];

const steps = [
  {
    step: "01",
    title: "Vous indiquez votre site",
    desc: "Une URL, une adresse email, et c’est parti. Pas besoin de créer un compte ou de sortir une carte bleue.",
  },
  {
    step: "02",
    title: "L’analyse se lance",
    desc: "Le diagnostic vérifie les bases techniques visibles : structure SEO, performance, images, sécurité et signaux utiles.",
  },
  {
    step: "03",
    title: "Vous recevez un rapport clair",
    desc: "Un résumé lisible, des priorités, et des pistes concrètes. Pas un pavé technique qui donne envie de fermer l’ordinateur.",
  },
];

const seo = {
  title: "Diagnostic visibilité web gratuit — CPEP",
  description:
    "Recevez un diagnostic gratuit de visibilité web pour identifier les points qui peuvent freiner votre site : SEO technique, performance, mobile, images et présence locale.",
  image: "/og-default.jpg",
  jsonLd: [
    {
      "@type": "WebPage",
      "@id": WEBPAGE_ID,
      url: abs("/diagnostic-visibilite/"),
      name: "Diagnostic visibilité web gratuit — CPEP",
      description:
        "Un pré-audit gratuit pour comprendre si votre site est clair, rapide, visible et correctement compris par les moteurs de recherche.",
      inLanguage: "fr-FR",
      isPartOf: { "@id": WEBSITE_ID },
      about: { "@id": ORG_ID },
      mainEntity: { "@id": SERVICE_ID },
    },
    {
      "@type": "Service",
      "@id": SERVICE_ID,
      name: "Diagnostic visibilité web gratuit",
      serviceType: "Pré-audit SEO, performance et visibilité web",
      description:
        "Analyse gratuite des bases techniques d’un site web : SEO on-page, performance, mobile, images, sécurité, présence locale et points de confiance.",
      provider: { "@id": ORG_ID },
      areaServed: "FR",
      audience: {
        "@type": "Audience",
        audienceType: "Entreprises, indépendants, commerces, associations et collectivités",
      },
      category: [
        "Audit SEO",
        "Diagnostic site web",
        "Performance web",
        "Visibilité locale",
        "Création de site web",
      ],
    },
  ],
};
---

<PageLayout {seo}>
  <main>
    <!-- Hero -->
    <section
      id="diagnostic-visibilite"
      aria-labelledby="diagnostic-title"
      class="relative isolate overflow-hidden px-4 py-24 md:py-32"
    >
      <!-- Halos -->
      <div
        class="pointer-events-none absolute -left-32 top-10 -z-10 h-96 w-96 rounded-full bg-primary/10 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -right-32 top-40 -z-10 h-96 w-96 rounded-full bg-accent/10 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <!-- Texte -->
        <div>
          <p class="inline-flex items-center gap-2 rounded-full border border-white/70 bg-white/55 px-4 py-2 text-sm font-medium uppercase tracking-[0.16em] text-primary shadow-sm backdrop-blur-xl">
            <Icon name="lucide:radar" class="h-4 w-4" aria-hidden="true" />
            Diagnostic visibilité web
          </p>

          <h1
            id="diagnostic-title"
            class="mt-8 max-w-4xl text-5xl font-bold leading-[0.95] text-text md:text-7xl"
          >
            Votre site est-il clair, rapide et visible&nbsp;?
          </h1>

          <p class="mt-8 max-w-2xl text-lg leading-relaxed text-text/85">
            Recevez un <strong>pré-audit gratuit</strong> de votre site web :
            SEO technique, performance, mobile, images et premiers signaux de confiance.
            L’objectif&nbsp;: comprendre rapidement ce qui aide — ou freine — votre visibilité.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="#formulaire-diagnostic"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(46,84,86,0.22)] transition hover:-translate-y-0.5 hover:shadow-[0_24px_55px_rgba(46,84,86,0.28)]"
            >
              Lancer mon diagnostic gratuit
              <Icon name="lucide:arrow-down" class="h-4 w-4" aria-hidden="true" />
            </a>

            <QuoteButton label="Parler de mon site" />
          </div>

          <p class="mt-5 text-sm text-text/60">
            Gratuit, sans jargon inutile, sans rapport de 48 pages. Promis, personne ne mérite ça.
          </p>
        </div>

        <!-- Carte score -->
        <div class="relative">
          <div
            class="pointer-events-none absolute -inset-8 rounded-full bg-accent/10 blur-3xl"
            aria-hidden="true"
          ></div>

          <article class="relative overflow-hidden rounded-3xl border border-white/75 bg-white/50 p-6 shadow-[0_24px_80px_rgba(8,7,8,0.12)] backdrop-blur-2xl">
            <div
              class="pointer-events-none absolute inset-0 bg-linear-to-br from-white/85 via-white/25 to-primary/10"
              aria-hidden="true"
            ></div>

            <div class="relative z-10">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-sm font-medium uppercase tracking-[0.16em] text-primary">
                    Exemple de lecture
                  </p>
                  <h2 class="mt-2 text-2xl font-bold text-text">
                    Score visibilité
                  </h2>
                </div>

                <div class="grid h-20 w-20 place-items-center rounded-full border border-primary/20 bg-white/60 text-xl font-bold text-primary shadow-sm">
                  78
                </div>
              </div>

              <div class="mt-8 space-y-4">
                <div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-medium text-text">SEO technique</span>
                    <span class="text-primary">Bon</span>
                  </div>
                  <div class="mt-2 h-2 overflow-hidden rounded-full bg-primary/10">
                    <div class="h-full w-[82%] rounded-full bg-primary"></div>
                  </div>
                </div>

                <div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-medium text-text">Performance</span>
                    <span class="text-primary">À surveiller</span>
                  </div>
                  <div class="mt-2 h-2 overflow-hidden rounded-full bg-primary/10">
                    <div class="h-full w-[68%] rounded-full bg-accent"></div>
                  </div>
                </div>

                <div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-medium text-text">Mobile</span>
                    <span class="text-primary">Correct</span>
                  </div>
                  <div class="mt-2 h-2 overflow-hidden rounded-full bg-primary/10">
                    <div class="h-full w-[74%] rounded-full bg-primary"></div>
                  </div>
                </div>
              </div>

              <div class="mt-8 rounded-2xl border border-white/70 bg-white/50 p-4">
                <p class="text-sm leading-relaxed text-text/75">
                  Le rapport indique les points forts, les problèmes prioritaires et les améliorations
                  simples à prévoir. Pas juste des voyants rouges pour faire peur.
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Promesse -->
    <section class="px-4 py-10">
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="mx-auto block h-px w-24 bg-linear-to-r from-transparent via-primary/45 to-transparent"
          aria-hidden="true"
        ></span>

        <p class="relative my-6 px-8 font-serif text-lg leading-relaxed text-text/80 md:px-12 md:text-xl">
          <span
            class="pointer-events-none absolute -left-1 -top-3 font-serif text-5xl leading-none text-accent/60 md:-left-2 md:-top-4 md:text-6xl"
            aria-hidden="true"
          >
            “
          </span>

          Un bon site ne se contente pas d’être joli.
          <span class="text-primary">
            Il doit être lisible, rapide, structuré et compréhensible
          </span>
          par vos visiteurs comme par les moteurs de recherche.

          <span
            class="pointer-events-none absolute -right-1 -bottom-6 font-serif text-5xl leading-none text-accent/60 md:-right-2 md:-bottom-7 md:text-6xl"
            aria-hidden="true"
          >
            ”
          </span>
        </p>

        <span
          class="mx-auto block h-px w-24 bg-linear-to-r from-transparent via-primary/45 to-transparent"
          aria-hidden="true"
        ></span>
      </div>
    </section>

    <!-- Points analysés -->
    <section class="relative isolate overflow-hidden px-4 py-20">
      <div
        class="pointer-events-none absolute left-1/2 top-20 -z-10 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-primary/6 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="mx-auto max-w-6xl">
        <div class="max-w-3xl">
          <p class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.18em] text-primary">
            <Icon name="lucide:list-checks" class="h-4 w-4" aria-hidden="true" />
            Ce qui est vérifié
          </p>

          <h2 class="mt-5 text-4xl font-bold text-text md:text-6xl">
            Un diagnostic simple, mais pas simpliste.
          </h2>

          <p class="mt-6 max-w-2xl text-text/80">
            L’outil vérifie les bases essentielles d’une page d’accueil.
            Le but n’est pas de remplacer un audit complet, mais de repérer vite
            les signaux faibles, les oublis et les priorités.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {auditPoints.map((point) => (
            <article class="group relative overflow-hidden rounded-2xl border border-white/80 bg-white/45 p-5 shadow-[0_18px_45px_rgba(8,7,8,0.08)] backdrop-blur-xl transition duration-300 hover:border-accent/50 hover:bg-white/55 hover:shadow-[0_24px_60px_rgba(8,7,8,0.12)]">
              <div
                class="pointer-events-none absolute inset-0 rounded-2xl bg-linear-to-br from-white/80 via-white/20 to-primary/10 opacity-70"
                aria-hidden="true"
              ></div>

              <div class="pointer-events-none absolute inset-x-4 top-0 h-px bg-linear-to-r from-transparent via-white/90 to-transparent" aria-hidden="true"></div>

              <div class="relative z-10">
                <div class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/70 bg-white/45 text-primary shadow-sm backdrop-blur-md">
                  <Icon name={point.icon} class="h-5 w-5" aria-hidden="true" />
                </div>

                <h3 class="mt-4 font-semibold text-text">
                  {point.title}
                </h3>

                <p class="mt-2 text-sm leading-relaxed text-text/80">
                  {point.desc}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Étapes -->
    <section class="px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
          <div>
            <p class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.18em] text-primary">
              <Icon name="lucide:workflow" class="h-4 w-4" aria-hidden="true" />
              Comment ça marche ?
            </p>

            <h2 class="mt-5 text-4xl font-bold text-text md:text-6xl">
              Trois étapes, pas de labyrinthe.
            </h2>

            <p class="mt-6 text-text/80">
              L’idée est volontairement simple : vous soumettez votre site,
              l’outil analyse les bases visibles, puis vous recevez une synthèse exploitable.
            </p>
          </div>

          <div class="space-y-4">
            {steps.map((item) => (
              <article class="relative overflow-hidden rounded-2xl border border-white/80 bg-white/45 p-5 shadow-[0_18px_45px_rgba(8,7,8,0.08)] backdrop-blur-xl">
                <div class="relative z-10 flex gap-5">
                  <div class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-primary text-sm font-bold text-white shadow-sm">
                    {item.step}
                  </div>

                  <div>
                    <h3 class="font-semibold text-text">
                      {item.title}
                    </h3>
                    <p class="mt-2 text-sm leading-relaxed text-text/75">
                      {item.desc}
                    </p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Formulaire -->
    <section
      id="formulaire-diagnostic"
      aria-labelledby="form-title"
      class="relative isolate overflow-hidden px-4 py-20"
    >
      <div
        class="pointer-events-none absolute -bottom-32 left-1/2 -z-10 h-96 w-96 -translate-x-1/2 rounded-full bg-accent/10 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="mx-auto max-w-4xl">
        <article class="relative overflow-hidden rounded-3xl border border-white/80 bg-white/55 p-6 shadow-[0_24px_80px_rgba(8,7,8,0.12)] backdrop-blur-2xl md:p-10">
          <div
            class="pointer-events-none absolute inset-0 bg-linear-to-br from-white/85 via-white/25 to-primary/10"
            aria-hidden="true"
          ></div>

          <div class="relative z-10">
            <div class="max-w-2xl">
              <p class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.18em] text-primary">
                <Icon name="lucide:send" class="h-4 w-4" aria-hidden="true" />
                Lancer le diagnostic
              </p>

              <h2 id="form-title" class="mt-5 text-4xl font-bold text-text md:text-5xl">
                Recevez votre pré-audit gratuit.
              </h2>

              <p class="mt-5 text-text/80">
                Cette première version du formulaire est prête côté interface.
                Il restera à brancher l’API PHP pour lancer l’analyse et envoyer le rapport par email.
              </p>
            </div>

            <form
            id="diagnostic-form"
            class="mt-8 grid gap-5"
            method="post"
            action="/api/diagnostic-visibilite.php"
            >
            <input id="started_at" type="hidden" name="started_at" value="" />

            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
                <label for="website">Site web</label>
                <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>

              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label for="url" class="text-sm font-medium text-text">
                    Adresse du site à analyser
                  </label>
                  <input
                    id="url"
                    name="url"
                    type="text"
                    required
                    placeholder="https://www.exemple.fr"
                    class="mt-2 w-full rounded-xl border border-white/80 bg-white/80 px-4 py-3 text-text shadow-sm outline-none transition placeholder:text-text/40 focus:border-accent focus:bg-white focus:ring-2 focus:ring-accent/25"
                  />
                </div>

                <div>
                  <label for="email" class="text-sm font-medium text-text">
                    Adresse email
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    placeholder="vous@entreprise.fr"
                    class="mt-2 w-full rounded-xl border border-white/80 bg-white/80 px-4 py-3 text-text shadow-sm outline-none transition placeholder:text-text/40 focus:border-accent focus:bg-white focus:ring-2 focus:ring-accent/25"
                  />
                </div>
              </div>

              <div>
                <label for="company" class="text-sm font-medium text-text">
                  Nom de l’entreprise <span class="text-text/45">(facultatif)</span>
                </label>
                <input
                  id="company"
                  name="company"
                  type="text"
                  placeholder="Votre entreprise"
                  class="mt-2 w-full rounded-xl border border-white/80 bg-white/80 px-4 py-3 text-text shadow-sm outline-none transition placeholder:text-text/40 focus:border-accent focus:bg-white focus:ring-2 focus:ring-accent/25"
                />
              </div>

              <label class="flex gap-3 rounded-2xl border border-white/70 bg-white/45 p-4 text-sm leading-relaxed text-text/75">
                <input
                  type="checkbox"
                  name="consent"
                  required
                  class="mt-1 h-4 w-4 rounded border-text/20 text-primary focus:ring-accent"
                />
                <span>
                  J’accepte que CPEP utilise ces informations pour m’envoyer le diagnostic gratuit
                  et puisse me recontacter au sujet de mon site. Pas de revente de données, pas de spam,
                  pas de tambourin marketing dans votre boîte mail.
                </span>
              </label>

              <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-center">
                <button
                  type="submit"
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(46,84,86,0.22)] transition hover:-translate-y-0.5 hover:shadow-[0_24px_55px_rgba(46,84,86,0.28)]"
                >
                  Recevoir mon diagnostic
                  <Icon name="lucide:mail-check" class="h-4 w-4" aria-hidden="true" />
                </button>

                <p class="text-sm text-text/55">
                  Rapport envoyé par email dans un premier temps.
                </p>
              </div>
            </form>
          </div>
        </article>
      </div>
    </section>

    <!-- Fin / CTA -->
    <section class="px-4 pb-24 pt-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-primary">
          Et après ?
        </p>

        <h2 class="mt-4 text-4xl font-bold text-text md:text-5xl">
          Un diagnostic automatique, puis une lecture humaine si besoin.
        </h2>

        <p class="mt-6 text-text/80">
          L’outil repère les premiers points techniques. Pour aller plus loin,
          CPEP peut vous aider à transformer ces constats en plan d’action :
          corrections SEO, optimisation de performance, refonte ou création de site.
        </p>

        <div class="mt-8 flex justify-center">
          <QuoteButton label="Demander un avis humain" />
        </div>
      </div>
    </section>
  </main>
</PageLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("#diagnostic-form");
  const startedAtInput = document.querySelector<HTMLInputElement>("#started_at");

  if (startedAtInput) {
    startedAtInput.value = Date.now().toString();
  }

  if (form) {
    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const initialButtonContent = submitButton?.innerHTML ?? "Recevoir mon diagnostic";

    const message = document.createElement("p");
    message.className =
      "mt-4 rounded-2xl border border-white/70 bg-white/60 px-4 py-3 text-sm text-text/80 shadow-sm backdrop-blur-xl";
    message.setAttribute("role", "status");
    message.setAttribute("aria-live", "polite");
    message.hidden = true;

    form.appendChild(message);

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!submitButton) return;

      message.hidden = true;
      message.textContent = "";

      submitButton.disabled = true;
      submitButton.classList.add("opacity-70", "cursor-wait");
      submitButton.textContent = "Analyse en cours...";

      try {
        const formData = new FormData(form);

        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        const data = await response.json();

        message.hidden = false;

        if (!response.ok || !data.success) {
          message.textContent =
            data.message || "Une erreur est survenue. Merci de réessayer.";
          message.className =
            "mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm";
          return;
        }

        message.textContent =
          "Votre diagnostic a bien été envoyé par email. Pensez à vérifier vos courriers indésirables si besoin.";
        message.className =
          "mt-4 rounded-2xl border border-primary/20 bg-white/70 px-4 py-3 text-sm text-primary shadow-sm backdrop-blur-xl";

        form.reset();

        if (startedAtInput) {
          startedAtInput.value = Date.now().toString();
        }
      } catch (error) {
        message.hidden = false;
        message.textContent =
          "Impossible d’envoyer la demande pour le moment. Merci de réessayer.";
        message.className =
          "mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm";
      } finally {
        submitButton.disabled = false;
        submitButton.classList.remove("opacity-70", "cursor-wait");
        submitButton.innerHTML = initialButtonContent;
      }
    });
  }
</script>