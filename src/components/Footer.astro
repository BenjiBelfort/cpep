---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();

const navLinks = [
  { label: 'Accueil', href: '/' },
  { label: 'Print', href: '/#print' },
  { label: 'Web', href: '/#web' },
  { label: 'Méthode', href: '/#methode' },
  // { label: 'FAQ', href: '/#faq' },
  { label: 'Contact', href: '/#contact' },
];

const legalLinks = [
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Confidentialité', href: '/politique-de-confidentialite' },
  { label: 'CGV', href: '/cgv' },
];

const contactLinks = [
  {
    label: 'contact@cpep.fr',
    href: 'mailto:contact@cpep.fr',
    icon: 'lucide:mail',
  },
  {
    label: '+33 6 13 99 12 31',
    href: 'tel:+33613991231',
    icon: 'lucide:phone',
  },
];

const linkClass =
  'transition hover:underline hover:decoration-accent hover:underline-offset-5 focus-visible:underline focus-visible:decoration-accent focus-visible:underline-offset-5';
---

<footer class="border-t border-bg-alt bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-4">
    <div class="md:col-span-1">
      <a href="/" aria-label="Retour à l’accueil CPEP" class="inline-flex items-center">
        <span class="font-display text-primary text-4xl leading-none">CPEP</span>
        <span class="font-display text-accent text-5xl leading-none rotate-4">!</span>
      </a>

      <p class="mt-3 max-w-xs text-sm leading-relaxed text-text/90">
        Supports de communication personnalisés, packaging, print, objets utiles
        et sites web sobres pour les entreprises.
      </p>

      <p class="mt-3 text-sm text-text/60">
        Basé en France · Projets sur mesure · Sur devis
      </p>
    </div>

    <nav aria-label="Navigation du pied de page">
      <h4 class="font-semibold text-text">Navigation</h4>

      <ul class="mt-3 space-y-2 text-sm">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={linkClass}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div>
      <h4 class="font-semibold text-text">Contact</h4>

      <ul class="mt-3 space-y-2 text-sm">
        {contactLinks.map((link) => (
          <li>
            <a href={link.href} class={`inline-flex items-center gap-2 ${linkClass}`}>
              <Icon name={link.icon} class="h-4 w-4 shrink-0" aria-hidden="true" />
              <span>{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <nav aria-label="Liens légaux">
      <h4 class="font-semibold text-text">Légal</h4>

      <ul class="mt-3 space-y-2 text-sm">
        {legalLinks.map((link) => (
          <li>
            <a href={link.href} class={linkClass}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="border-t border-bg-alt bg-primary">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-5 text-xs text-bg max-sm:flex-col max-sm:text-center">
      <span>
        © {year} CPEP! — Tous droits réservés
      </span>

      <span class="flex items-center gap-1 opacity-90 transition hover:opacity-100">
        <span>Site créé avec</span>
        <img
          src="/logo/astro-logo-light-gradient.svg"
          alt="Astro"
          class="h-8 w-auto translate-y-[1px]"
          loading="lazy"
        />
      </span>
    </div>
  </div>
</footer>