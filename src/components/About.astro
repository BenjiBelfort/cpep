---
// src/components/sections/About.astro
import { Icon } from 'astro-icon/components';

type ValueItem = {
  icon: string;
  title: string;
  desc: string;
  badge?: boolean;  // pour mettre un macaron "priorité"
};

const values: ValueItem[] = [
  {
    icon: 'lucide:scale',
    title: 'Justesse & clarté',
    desc: 'Des tarifs adaptés au projet, des choix transparents et une approche honnête : proposer ce qui a vraiment de la valeur.',
    badge: true,
  },
  {
    icon: 'lucide:handshake',
    title: 'Relation avant volume',
    desc: 'Peu de clients, plus d’attention. Un suivi humain, réactif et pensé pour construire dans la durée.',
    badge: true,
  },
  {
    icon: 'lucide:factory',
    title: 'Sourcing maîtrisé',
    desc: 'Des produits sélectionnés avec soin, principalement en France et en Europe, selon leur qualité, leur usage et leur fiabilité.',
    badge: true,
  },
  {
    icon: 'lucide:check-circle-2',
    title: 'Utilité concrète',
    desc: 'Chaque support doit servir un vrai besoin : sacs, emballages, print ou web. Beau, oui. Utile, surtout.',
  },
  {
    icon: 'lucide:wand-2',
    title: 'Simplicité efficace',
    desc: 'Des échanges clairs, des étapes lisibles et le moins de friction possible. Quand c’est fluide, tout le monde respire.',
  },
  {
    icon: 'lucide:heart-handshake',
    title: 'Impact durable',
    desc: 'Construire une communication plus responsable, avec des partenaires de confiance et, à terme, des opportunités pour de jeunes talents.',
  },
];

---
<section
  id="about"
  aria-labelledby="about-title"
  class="relative isolate scroll-m-4 overflow-x-clip bg-linear-to-t from-primary to-creative"
>
  <div class="mx-auto px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="my-12 flex justify-center">
        <p class="inline-flex flex-col items-center gap-2 text-center text-sm font-medium uppercase tracking-[0.18em] text-primary sm:flex-row sm:text-left">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/70 sm:h-auto sm:w-auto sm:bg-transparent">
            <Icon
              name="lucide:heart-handshake"
              class="h-5 w-5 sm:h-4 sm:w-4"
              aria-hidden="true"
            />
          </span>

          <span>À propos de CPEP!</span>
        </p>
      </div>

      <div class="mx-auto max-w-3xl text-center">
        <h2
          id="about-title"
          class="mt-3 text-2xl font-medium text-text md:text-3xl"
        >
          Des supports utiles, durables, bien pensés
        </h2>

        <p class="mt-4 text-text">
          Nous concevons des <strong>solutions de communication physiques</strong> —
          packaging, sacs personnalisés, print et objets utiles — pour des entreprises
          qui veulent une image cohérente, responsable et faite pour durer.
          Le web vient compléter cette approche avec des sites sobres, clairs et efficaces.
        </p>
      </div>

    <section class="mx-auto my-16 grid max-w-5xl gap-12" aria-label="Mission et vision CPEP">
      <!-- Trait haut -->
      <div class="flex justify-center" aria-hidden="true">
        <span class="h-px w-24 bg-white/80"></span>
      </div>
      <!-- Mission -->
      <div class="grid items-center gap-4 overflow-visible py-16 md:grid-cols-2 md:py-24">
        <div class="relative z-10">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">
            Mission
          </p>

          <h3 class="mt-2 text-3xl font-bold text-text md:text-5xl">
            Concevoir des supports utiles, durables et bien sourcés.
          </h3>

          <p class="mt-4 max-w-2xl text-text/95">
            Packaging, sacs, print et objets personnalisés : nous aidons les entreprises
            à faire les bons choix, avec des partenaires fiables, principalement en France
            et en Europe. Le web vient compléter cette approche avec des sites sobres,
            clairs et efficaces.
          </p>
        </div>

        <!-- Illustration mission -->
        <div
          class="relative flex min-h-[22rem] items-center justify-center overflow-visible md:min-h-[30rem] md:justify-end"
          aria-hidden="true"
        >
          <img
            src="/photos/mission.webp"
            alt=""
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            class="relative z-0 w-full max-w-none object-contain md:w-[135%] md:translate-x-40"
          />
        </div>
      </div>

      <!-- Séparateur étoiles -->
      <div class="flex items-center justify-center gap-3" aria-hidden="true">
        <span class="h-px w-16 bg-white/50"></span>

        <div class="flex items-center gap-1.5 text-2xl leading-none text-white/80">
          {Array.from({ length: 5 }).map(() => (
            <span aria-hidden="true">★</span>
          ))}
        </div>

        <span class="h-px w-16 bg-white/50"></span>
      </div>

      <!-- Vision -->
      <div class="grid items-stretch gap-8 md:grid-cols-2 py-16">
        <!-- Illustration future -->
        <div
          class="order-2 min-h-56 rounded-2xl md:order-1"
          aria-hidden="true"
        >
          <div class="flex h-full min-h-56 items-center justify-center p-6 text-center">

          </div>
        </div>

        <div class="order-1 md:order-2 md:text-left">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">
            Vision
          </p>

          <h3 class="mt-2 text-3xl font-bold text-text md:text-5xl">
            Faire de la communication un levier concret, responsable et durable.
          </h3>

          <p class="mt-4 text-text/95">
            Loin du jetable, du gadget et des discours creux, nous voulons aider les
            entreprises à construire une image cohérente, élégante et pleine de bon sens —
            du packaging au site web, avec la même exigence de clarté, de justesse et de qualité.
          </p>
        </div>
      </div>

        <!-- Trait bas -->
        <div class="flex justify-center" aria-hidden="true">
          <span class="h-px w-24 bg-white/50"></span>
        </div>
    </section>

    <section class="my-16" aria-label="values-title">
      <aside class="mx-auto w-fit mt-10 text-2xl">
          <div class="flex items-center gap-4">
              <img
                  src="/logo/certified.png"
                  alt=""
                  width="40"
                  height="40"
                  loading="lazy"
                  decoding="async"
                  class="h-12 w-12 object-contain drop-shadow-md"
              />
              <div class="flex-1 mb-4">
                  <h3 class="font-semibold text-white font-serif">Nos valeurs clés !</h3>
                  <p class="text-white font-serif">Seulement <strong>l’essentiel</strong>. Échanges <strong>simples</strong>. Partenaires <strong>proches</strong>.</p>
              </div>
          </div>
      </aside>

      <ul class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {values.map((v) => (
          <li class="relative rounded-xl border border-bg-alt bg-white p-5 hover:shadow-sm transition">
              {/* Badge certif en haut-droite (seulement si v.badge === true) */}
              {v.badge && (
              <span class="absolute -top-2 -right-2 z-10 pointer-events-none select-none" aria-hidden="true">
                  <img
                  src="/logo/certified.png"
                  alt=""
                  width="28"
                  height="28"
                  loading="lazy"
                  decoding="async"
                  class="h-7 w-7 object-contain drop-shadow-sm"
                  />
              </span>
              )}


              <div class="flex-col items-start gap-3">
              <Icon name={v.icon} class="h-6 w-6 text-primary" aria-hidden="true" />
              <p class="font-semibold text-primary">{v.title}</p>
              <p class="mt-1 text-sm text-gray-800">{v.desc}</p>
              </div>
          </li>
          ))}
      </ul>
    </section>
    </div>
  </div>
</section>
