---
const cardHref = "/benjamin";

const socialLinks = [
  {
    href: "https://www.linkedin.com/in/benjamin-tisserand-dev/",
    label: "Voir le profil LinkedIn de Benjamin Tisserand",
    icon: "/logo/linkedIn-icon.svg",
    name: "LinkedIn",
  },
  {
    href: "https://www.instagram.com/benjamin_tisserand/",
    label: "Voir le profil Instagram de Benjamin Tisserand",
    icon: "/logo/Instagram-logo.svg",
    name: "Instagram",
  },
  {
    href: "https://github.com/BenjiBelfort",
    label: "Voir le profil GitHub de Benjamin Tisserand",
    icon: "/logo/GitHub-logo.svg",
    name: "GitHub",
  },
];
---

<section
  id="qui-sommes-nous"
  aria-labelledby="about-signature-title"
  class="relative mx-auto scroll-m-4"
>
  <article
    class="relative overflow-visible bg-white/75 px-5 pb-6 pt-28 shadow-[0_22px_70px_rgba(8,7,8,0.10)] ring-1 ring-white/80 backdrop-blur-xl md:px-10 md:py-10 md:pl-64"
  >
    <!-- Photo qui déborde façon signature -->
    <div
      class="absolute -top-16 left-6 z-10 flex items-end gap-3 md:-top-14 md:left-10 md:flex-col md:items-center md:gap-0"
    >
      <div
        class="relative h-40 w-40 rounded-full bg-white p-2 shadow-[0_20px_55px_rgba(8,7,8,0.16)] ring-1 ring-black/5 md:h-48 md:w-48"
      >
        <!-- Image portrait -->
        <img
          id="benjamin-photo-portrait"
          src="/photos/benjamin.webp"
          alt="Benjamin Tisserand"
          width="420"
          height="420"
          loading="lazy"
          decoding="async"
          class="absolute inset-2 h-[calc(100%-1rem)] w-[calc(100%-1rem)] rounded-full object-cover opacity-100 transition-opacity duration-1000 ease-in-out"
        />

        <!-- Image au travail -->
        <img
          id="benjamin-photo-work"
          src="/photos/benjamin-at-work.webp"
          alt=""
          width="420"
          height="420"
          loading="lazy"
          decoding="async"
          class="absolute inset-2 h-[calc(100%-1rem)] w-[calc(100%-1rem)] rounded-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out"
        />

        <!-- Petit point accent cliquable -->
        <button
          type="button"
          id="benjamin-photo-button"
          aria-label="Changer la photo de Benjamin"
          aria-pressed="false"
          class="absolute bottom-4 right-4 z-30 h-6 w-6 cursor-pointer rounded-full border-4 border-white bg-success shadow-sm transition-colors duration-0 hover:scale-125 hover:bg-accent focus:outline-none focus-visible:ring-4 focus-visible:ring-accent/30 disabled:pointer-events-none"
        >
          <span class="sr-only">Changer la photo</span>
        </button>
      </div>

      <!-- Réseaux -->
      <div class="mb-2 flex shrink-0 items-center justify-center gap-1 md:mb-0 md:mt-3 md:flex-col">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            title={social.name}
            class="grid h-12 w-12 place-items-center rounded-full bg-white transition hover:shadow-md"
          >
            <img
              src={social.icon}
              alt=""
              width="26"
              height="26"
              loading="lazy"
              decoding="async"
              class="h-6 w-6"
            />
          </a>
        ))}
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_260px] lg:items-center">
      <div>
        <h2
          id="about-signature-title"
          class="text-xl font-bold leading-tight text-text md:text-2xl"
        >
          <span class="text-text/90">Entre packaging, terrain et développement web</span> <br />
            <span
              id="benjamin-dynamic-title"
              class="inline-block max-w-full break-words text-3xl transition-all duration-500 ease-out md:text-4xl"
            >
              Hello, je suis Benjamin.
            </span>
        </h2>

        <p class="mt-4 max-w-2xl text-base leading-relaxed text-text/90 md:text-lg">
          Avec plus de 25 ans d’expérience dans l’emballage, le packaging,
          le print et les supports personnalisés, j’aide les entreprises à faire
          les bons choix pour leurs emballages et supports de communication :
          <strong>utiles, durables, bien sourcés et bien placés</strong>.
        </p>

        <p class="mt-3 max-w-2xl text-base leading-relaxed text-text/85">
          Depuis 2024, j’ai intégré le développement web pour créer mes propres
          outils, automatiser ce qui peut l’être, et gagner en efficacité. Cette
          approche me permet aujourd’hui de proposer à mes clients des solutions
          digitales utiles, sobres et pensées pour leur quotidien.
        </p>
      </div>

      <!-- CTA contact -->
      <div
        class="group relative block overflow-hidden rounded-sm bg-primary p-3 text-white shadow-[0_18px_45px_rgba(60,110,113,0.24)] transition duration-300 hover:shadow-[0_24px_60px_rgba(60,110,113,0.30)]"
      >
        <!-- reflet -->
        <span
          class="pointer-events-none absolute inset-0 bg-linear-to-br from-white/25 via-white/5 to-transparent opacity-80"
          aria-hidden="true"
        ></span>

        <!-- petit motif grille discret -->
        <span
          class="pointer-events-none absolute inset-0 opacity-15"
          style="background-image: linear-gradient(rgba(255,255,255,.45) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.45) 1px, transparent 1px); background-size: 18px 18px;"
          aria-hidden="true"
        ></span>

        <div class="relative flex min-h-40 flex-col justify-between">
          <div>
            <span class="block text-xs font-bold uppercase tracking-[0.18em] text-white/70">
              Contact
            </span>

            <div class="mt-4 grid gap-3">
              <a
                href={cardHref}
                aria-label="Voir la carte de visite de Benjamin Tisserand"
                class="group/link flex items-center justify-between gap-4 rounded-xl bg-white/10 px-4 py-3 text-left transition hover:bg-white/16"
              >
                <span class="text-sm font-bold leading-snug">
                  Carte de visite <br /> Benjamin TISSERAND
                </span>

                <span
                  class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-white text-primary transition group-hover/link:translate-x-1"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>

              <a
                href="/#contact"
                aria-label="Aller au formulaire de contact"
                class="group/link flex items-center justify-between gap-4 rounded-xl bg-white/10 px-4 py-3 text-left transition hover:bg-white/16"
              >
                <span class="text-sm font-bold leading-snug">
                  Formulaire de contact
                </span>

                <span
                  class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-white text-primary transition group-hover/link:translate-x-1"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            </div>
          </div>

          <p class="mt-5 text-sm text-white/70">
            Une question, un projet, un devis&nbsp;?
          </p>
        </div>
      </div>
    </div>
  </article>
</section>

<script>
  const photoButton = document.querySelector("#benjamin-photo-button");
  const portraitImage = document.querySelector("#benjamin-photo-portrait");
  const workImage = document.querySelector("#benjamin-photo-work");
  const dynamicTitle = document.querySelector("#benjamin-dynamic-title");

  const helloTitles = [
    "Hello, je suis Benjamin.",
    "Bonjour, je suis Benjamin.",
  ];

  const workTitles = [
    "npm run boss — Benjamin is bossing.",
    "const benji = enModeProd();",
    "git commit -m \"ça part en prod !\"",
    "Benjamin.compile (projetClient);",
    "while(project) { coffee++; ship(); }",
  ];

  const backTitles = [
    "Je suis Benjamin, comment puis-je vous aider ?",
    "Benjamin de retour. Print, web ou les deux ?",
    "Disponible pour parler sacs, sites et bonnes idées.",
    "Un projet print ou web ? Je vous écoute.",
  ];

  let isWorkPhotoVisible = false;
  let isAnimating = false;
  let clickCount = 0;

  let shuffledWorkTitles: string[] = [];
  let shuffledBackTitles: string[] = [];

  function shuffleItems(items: string[]) {
    return [...items].sort(() => Math.random() - 0.5);
  }

  function getRandomItem(items: string[]) {
    return items[Math.floor(Math.random() * items.length)];
  }

  function getNextShuffledWorkTitle() {
    if (shuffledWorkTitles.length === 0) {
      shuffledWorkTitles = shuffleItems(workTitles);
    }

    return shuffledWorkTitles.shift() || getRandomItem(workTitles);
  }

  function getNextShuffledBackTitle() {
    if (shuffledBackTitles.length === 0) {
      shuffledBackTitles = shuffleItems(backTitles);
    }

    return shuffledBackTitles.shift() || getRandomItem(backTitles);
  }

  function setRandomInitialTitle() {
    if (!dynamicTitle) return;

    dynamicTitle.textContent = getRandomItem(helloTitles);
  }

  function updateTitle(text: string, mode: "default" | "code" = "default") {
    if (!dynamicTitle) return;

    dynamicTitle.classList.add("opacity-0", "translate-y-1");

    window.setTimeout(() => {
      dynamicTitle.textContent = text;

      if (mode === "code") {
        dynamicTitle.classList.add(
          "max-w-full",
          "rounded-lg",
          "bg-text",
          "px-3",
          "py-1.5",
          "font-mono",
          "text-xl",
          "text-creative",
          "shadow-sm",
          "break-words",
          "md:text-2xl"
        );

        dynamicTitle.classList.remove("text-3xl", "md:text-4xl");
      } else {
        dynamicTitle.classList.remove(
          "max-w-full",
          "rounded-lg",
          "bg-text",
          "px-3",
          "py-1.5",
          "font-mono",
          "text-xl",
          "text-creative",
          "shadow-sm",
          "break-words",
          "md:text-2xl"
        );

        dynamicTitle.classList.add("text-3xl", "md:text-4xl");
      }

      dynamicTitle.classList.remove("opacity-0", "translate-y-1");
    }, 250);
  }

  function showPortraitMode() {
    workImage?.classList.remove("opacity-100");
    workImage?.classList.add("opacity-0");

    portraitImage?.classList.remove("opacity-0");
    portraitImage?.classList.add("opacity-100");

    photoButton?.classList.remove("bg-accent");
    photoButton?.classList.add("bg-success");

    isWorkPhotoVisible = false;
    photoButton?.setAttribute("aria-pressed", "false");
  }

  function showWorkMode() {
    portraitImage?.classList.remove("opacity-100");
    portraitImage?.classList.add("opacity-0");

    workImage?.classList.remove("opacity-0");
    workImage?.classList.add("opacity-100");

    photoButton?.classList.remove("bg-success");
    photoButton?.classList.add("bg-accent");

    isWorkPhotoVisible = true;
    photoButton?.setAttribute("aria-pressed", "true");
  }

  function lockButtonAfterVictory() {
    showPortraitMode();

    photoButton?.setAttribute("disabled", "true");
    photoButton?.setAttribute("aria-label", "Mini-jeu terminé");
    photoButton?.classList.remove(
      "bg-success",
      "bg-accent",
      "hover:bg-accent",
      "hover:scale-125",
      "cursor-pointer"
    );
    photoButton?.classList.add(
      "bg-bg-alt",
      "cursor-not-allowed",
    );

    updateTitle("Bravo 50 clics ! On bosse ensemble ?", "default");
  }

  function getSpecialTitle() {
    if (clickCount === 7) {
      return {
        text: "7 clics = spam mode activé.",
        mode: "code" as const,
      };
    }

    if (clickCount === 14) {
      return {
        text: `${clickCount} clics sur ce bouton ! Vous êtes tenace.`,
        mode: "default" as const,
      };
    }

    if (clickCount === 21) {
      return {
        text: "function hireBenjamin() { return \"bonne idée\"; }",
        mode: "code" as const,
      };
    }

    if (clickCount === 28) {
      return {
        text: `${clickCount} clics... est-ce que TVB ?`,
        mode: "default" as const,
      };
    }

    if (clickCount > 28 && clickCount < 50) {
      if (isWorkPhotoVisible) {
        return {
          text: "contactForm.submit() // bonne idée !",
          mode: "code" as const,
        };
      }

      return {
        text: "Vous voulez pas plutôt m’envoyer un mail ?",
        mode: "default" as const,
      };
    }

    return null;
  }

  setRandomInitialTitle();

  photoButton?.addEventListener("click", () => {
    if (isAnimating || clickCount >= 50) return;

    clickCount++;

    if (clickCount === 50) {
      lockButtonAfterVictory();
      return;
    }

    isAnimating = true;

    if (isWorkPhotoVisible) {
      showPortraitMode();
    } else {
      showWorkMode();
    }

    const specialTitle = getSpecialTitle();

    if (specialTitle) {
      updateTitle(specialTitle.text, specialTitle.mode);
    } else if (isWorkPhotoVisible) {
      updateTitle(getNextShuffledWorkTitle(), "code");
    } else {
      updateTitle(getNextShuffledBackTitle(), "default");
    }

    window.setTimeout(() => {
      photoButton.removeAttribute("disabled");
      isAnimating = false;
    }, 1500);
  });
</script>