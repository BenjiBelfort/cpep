---
// src/components/ui/QuoteButton.astro
import { Icon } from "astro-icon/components";

type Props = {
  href?: string;
  label?: string;
  class?: string;
};

const {
  href = "/#contact",
  label = "Demander un devis",
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "group inline-flex items-center justify-center gap-2 rounded-full border border-primary/30 bg-white/70 px-6 py-3 font-medium text-primary backdrop-blur-md transition hover:border-primary hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent",
    className,
  ]}
>
  <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />

  <span class="text-sm md:text-base">{label}</span>

  <Icon
    name="lucide:arrow-right"
    class="h-4 w-4 opacity-0 transition duration-200 group-hover:translate-x-1 group-hover:opacity-100"
    aria-hidden="true"
  />
</a>