---
// src/components/WebTeaserSection.astro
import { Icon } from "astro-icon/components";
import ImageCarousel from "./ui/ImageCarousel.astro";
import QuoteButton from "./ui/QuoteButton.astro";

const webCarouselImages = [
  {
    src: "/photos/web-site-vitrine.webp",
    alt: "Création de site web vitrine sur mesure",
    caption: "Sites vitrines rapides, sobres et bien structurés",
  },
  {
    src: "/photos/sites-web-responsives.webp",
    alt: "Site web responsive adapté mobile tablette et desktop",
    caption: "Design responsive pensé pour tous les écrans",
  },
  {
    src: "/photos/web-seo.webp",
    alt: "Optimisation SEO technique pour site web",
    caption: "SEO technique, structure propre et performances",
  },
  {
    src: "/photos/web-dev-specifique.webp",
    alt: "Développement web spécifique et intégrations API",
    caption: "Développement spécifique, automatisations et intégrations",
  },
];
---

<section id="web" aria-labelledby="web-title" class="relative scroll-m-4">
  <div class="mx-auto px-4 py-20 cpep-web-radial">
    <div class="my-12 flex justify-center">
      <p class="inline-flex flex-col items-center gap-2 text-center text-sm font-medium uppercase tracking-[0.18em] text-primary sm:flex-row sm:text-left">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 sm:h-auto sm:w-auto sm:bg-transparent">
          <Icon name="lucide:code-2" class="h-5 w-5 sm:h-4 sm:w-4" aria-hidden="true" />
        </span>

        <span>Sites web sur mesure & développement utile</span>
      </p>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="grid min-w-0 items-center gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <!-- Carousel image gauche -->
        <div class="order-2 min-w-0 lg:order-1">
          <ImageCarousel
            images={webCarouselImages}
            ariaLabel="Exemples de services web CPEP"
            autoplayDelay={4000}
          />
        </div>

        <!-- Colonne texte droite -->
        <div class="contents min-w-0 lg:order-2 lg:block">
          <h2
            id="web-title"
            class="order-1 mt-6 text-left text-5xl font-bold text-text md:text-7xl lg:mt-6"
          >
            Des sites web sobres, rapides et faits pour durer.
          </h2>

          <div class="order-3 text-left lg:order-none">
            <p class="mt-6 max-w-3xl text-text/90">
              Nous créons des <strong>sites web sur mesure</strong> pensés pour être clairs,
              rapides, bien référencés et faciles à faire évoluer. Site vitrine, refonte,
              landing page, intégration, automatisation ou développement spécifique :
              l’objectif est simple, construire un outil utile, performant et aligné avec
              votre communication globale.
            </p>

            <p class="mt-4 max-w-2xl text-sm text-text/80">
              Ici, pas de site usine à gaz avec quinze animations qui font chauffer le grille-pain.
              Nous privilégions une structure propre, un contenu lisible, un bon socle SEO,
              des performances solides et une expérience fluide sur mobile comme sur desktop.
            </p>

            <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
              <QuoteButton label="Parler de mon projet web" />
            </div>
          </div>
        </div>
      </div>

      <p class="mx-auto mt-12 max-w-3xl text-center text-sm leading-relaxed text-text/80">
        Un bon site web n’est pas seulement une vitrine : c’est un support de confiance,
        un point d’entrée commercial et un outil qui doit rester simple à maintenir.
        Nous travaillons le design, le SEO technique, l’accessibilité, la performance et
        la structure pour que le site serve vraiment votre activité.
      </p>

      <!-- Services rapides -->
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <article class="rounded-2xl border border-bg-alt bg-white/80 p-5 shadow-sm transition hover:shadow-md">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
            <Icon name="lucide:monitor-smartphone" class="h-5 w-5" aria-hidden="true" />
          </div>

          <h3 class="mt-4 font-semibold text-text">
            Création de sites web
          </h3>

          <p class="mt-2 text-sm leading-relaxed text-text/80">
            Sites vitrines rapides, responsive, bien structurés et optimisés pour le SEO on-page.
          </p>
        </article>

        <article class="rounded-2xl border border-bg-alt bg-white/80 p-5 shadow-sm transition hover:shadow-md">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
            <Icon name="lucide:gauge" class="h-5 w-5" aria-hidden="true" />
          </div>

          <h3 class="mt-4 font-semibold text-text">
            Performance & SEO technique
          </h3>

          <p class="mt-2 text-sm leading-relaxed text-text/80">
            Balises, structure, maillage, données structurées, accessibilité et Core Web Vitals.
          </p>
        </article>

        <article class="rounded-2xl border border-bg-alt bg-white/80 p-5 shadow-sm transition hover:shadow-md">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary">
            <Icon name="lucide:workflow" class="h-5 w-5" aria-hidden="true" />
          </div>

          <h3 class="mt-4 font-semibold text-text">
            Développement spécifique
          </h3>

          <p class="mt-2 text-sm leading-relaxed text-text/80">
            Intégrations API, formulaires avancés, back-offices, automatisations et outils métier.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>