---
// src/components/WebTeaserSection.astro
import { Icon } from "astro-icon/components";
import QuoteButton from "./ui/QuoteButton.astro";

const webCards = [
  {
    icon: "lucide:monitor-smartphone",
    title: "Création de sites web",
    desc: "Sites vitrines rapides, responsive, bien structurés et optimisés pour le SEO on-page.",
  },
  {
    icon: "lucide:gauge",
    title: "Performance & SEO technique",
    desc: "Balises, structure, maillage, données structurées, accessibilité et Core Web Vitals.",
  },
  {
    icon: "lucide:workflow",
    title: "Développement spécifique",
    desc: "Intégrations API, formulaires avancés, back-offices, automatisations et outils métier.",
  },
];

const webProjects = [
  {
    slug: "ems-audit",
    name: "EMS Audit",
    image: "/photos/web/sites-web-responsives-ems.webp",
    href: "https://www.emsaudit.com/",
    alt: "Site web responsive EMS Audit adapté mobile tablette et desktop",
  },
  {
    slug: "happy-dog-belfort",
    name: "Happy Dog Belfort",
    image: "/photos/web/sites-web-responsives-happy.webp",
    href: "https://www.happy-dog-belfort.fr/",
    alt: "Site web responsive Happy Dog Belfort adapté mobile tablette et desktop",
  },
  {
    slug: "baptiste-jeandel",
    name: "Baptiste Jeandel",
    image: "/photos/web/sites-web-responsives-baptiste-jeandel.webp",
    href: "https://www.baptistejeandel.fr/",
    alt: "Site web responsive Baptiste Jeandel adapté mobile tablette et desktop",
  },
  {
    slug: "batuca-noventa",
    name: "Batuca Noventa",
    image: "/photos/web/sites-web-responsives-batuca-noventa.webp",
    href: "https://www.batucanoventa.fr/",
    alt: "Site web responsive Batuca Noventa adapté mobile tablette et desktop",
  },
  {
    slug: "best-off-music",
    name: "Best Off Music",
    image: "/photos/web/sites-web-responsives-best-off.webp",
    href: "https://bestoffmusic.fr/",
    alt: "Site web responsive Best Off Music adapté mobile tablette et desktop",
  },
  {
    slug: "phil-bullet-art",
    name: "Phil Bullet Art",
    image: "/photos/web/sites-web-responsives-phil-bullet-art.webp",
    href: "https://www.bullet-art.com/",
    alt: "Site web responsive Phil Bullet Art adapté mobile tablette et desktop",
  },
  {
    slug: "bs-courtage",
    name: "BS Courtage",
    image: "/photos/web/sites-web-responsives-bs-courtage.webp",
    href: "https://www.bscourtage.com/",
    alt: "Site web responsive BS Courtage adapté mobile tablette et desktop",
  },
    {
    slug: "cpep",
    name: "CPEP",
    image: "/photos/web/sites-web-responsives-cpep.webp",
    href: "https://www.cpep.fr/",
    alt: "Site web responsive CPEP adapté mobile tablette et desktop",
    isCurrentSite: true,
  },
  {
    slug: "nina-havre-abeille-bleue",
    name: "Le Havre de l'Abeille Bleue",
    image: "/photos/web/sites-web-responsives-le-havre-de-l-abeille-bleue.webp",
    href: "https://belfort-naturopathe.fr/",
    alt: "Site web responsive Le Havre de l'Abeille Bleue adapté mobile tablette et desktop",
  },
];

---

<section
  id="web"
  aria-labelledby="web-title"
  class="relative isolate scroll-m-4 overflow-x-clip"
>

  <div class="mx-auto px-4 py-20 cpep-web-radial">
    <div class="relative z-20 my-12 flex justify-center">
      <p class="inline-flex flex-col items-center gap-2 text-center text-sm font-medium uppercase tracking-[0.18em] text-primary sm:flex-row sm:text-left">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 sm:h-auto sm:w-auto sm:bg-transparent">
          <Icon name="lucide:code-2" class="h-5 w-5 sm:h-4 sm:w-4" aria-hidden="true" />
        </span>

        <span>Sites web sur mesure & développement utile</span>
      </p>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="grid min-w-0 items-center gap-5 md:gap-15 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <!-- Image web gauche -->
        <div class="order-2 min-w-0 lg:order-1">
          <div class="relative mx-auto flex max-w-xl items-center justify-center lg:mx-0 lg:max-w-none lg:justify-start">
            <!-- Halo de mise en valeur : accent pour le web -->
            <div
              class="pointer-events-none absolute -left-20 -top-10 h-72 w-72 rounded-full bg-accent/8 blur-3xl lg:-left-40 lg:-top-24 lg:h-96 lg:w-96"
              aria-hidden="true"
            ></div>

            <!-- Halo accent discret -->
            <!-- <div
              class="pointer-events-none absolute bottom-8 right-4 h-56 w-56 rounded-full bg-accent/8 blur-3xl lg:-bottom-2 lg:right-10 lg:h-72 lg:w-72"
              aria-hidden="true"
            ></div> -->

            <!-- Ombre posée -->
            <!-- <div
              class="pointer-events-none absolute bottom-2 left-1/2 h-10 w-[78%] -translate-x-1/2 rounded-full bg-black/12 blur-2xl lg:left-0 lg:w-[90%] lg:translate-x-0"
              aria-hidden="true"
            ></div> -->

            <!-- Image sans cadre, volontairement débordante -->
            <figure class="relative z-0">
              <img
                id="web-showcase-image"
                src={webProjects[0].image}
                alt={webProjects[0].alt}
                width="900"
                height="900"
                loading="eager"
                fetchpriority="low"
                decoding="async"
                class="w-[115%] max-w-none -translate-x-6 -translate-y-6 object-contain drop-shadow-xl/20 sm:w-[105%] lg:w-[135%] lg:-translate-x-32 lg:-translate-y-20 xl:w-[150%] xl:-translate-x-44 xl:-translate-y-28"
              />
              <button
                id="web-showcase-switch"
                type="button"
                class="absolute left-1/2 bottom-12 z-20 inline-flex -translate-x-1/2 cursor-pointer items-center justify-center rounded-full border border-white/70 bg-white/75 p-2.5 text-primary shadow-lg backdrop-blur-xl transition hover:bg-white/90 hover:text-accent lg:bottom-28"
                aria-label="Changer le visuel présenté"
              >
                <Icon
                  name="lucide:refresh-ccw"
                  class="web-showcase-switch-icon h-4 w-4"
                  aria-hidden="true"
                />
              </button>
              <figcaption
                id="web-showcase-caption"
                class="absolute left-1/2 bottom-2 z-10 flex -translate-x-1/2 items-center justify-center gap-2 whitespace-nowrap text-center text-xs text-text/60 lg:bottom-18"
              >
                <span>
                  Réalisation web : <span id="web-showcase-name">{webProjects[0].name}</span>
                </span>

                <a
                  id="web-showcase-caption-link"
                  href={webProjects[0].href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex h-6 w-6 items-center justify-center rounded-full text-text/60 transition hover:bg-white/55 hover:text-accent"
                  aria-label={`Visiter le site ${webProjects[0].name}`}
                >
                  <Icon
                    name="lucide:external-link"
                    class="h-3.5 w-3.5"
                    aria-hidden="true"
                  />
                </a>
              </figcaption>
            </figure>
          </div>
        </div>

        <!-- Colonne texte droite -->
        <div class="contents min-w-0 lg:order-2 lg:block">
          <h2
            id="web-title"
            class="relative z-20 order-1 mt-6 text-left text-5xl font-bold text-text md:text-6xl lg:mt-6 lg:text-7xl"
          >
            Sites web sobres, rapides et responsives, pensés pour servir votre activité.
          </h2>
          <div class="order-3 text-left lg:order-none">
            <p class="md:mt-6 max-w-3xl text-text/90">
              Nous créons des <strong>sites web sur mesure</strong> pensés pour être clairs,
              rapides, bien référencés et surtout <strong>responsives</strong>. Site vitrine, refonte,
              landing page, intégration, automatisation ou développement spécifique :
              l’objectif est simple, construire un outil utile, performant et aligné avec
              votre communication globale.
            </p>


            <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
              <!-- <QuoteButton variant="primary" label="Voir nos réalisations" icon="lucide:code-2" href="/developpement-web"/> -->
              <QuoteButton label="Parler de mon projet web" />
              <!-- <QuoteButton label="Parler de mon projet web" href="/devis-site-web" /> -->
            </div>
          </div>
        </div>
      </div>

      <!-- manifeste -->
      <div class="mx-auto my-24 max-w-3xl text-center">
        <span
          class="mx-auto block h-px w-24 bg-linear-to-r from-transparent via-primary/45 to-transparent"
          aria-hidden="true"
        ></span>

        <p class="relative my-6 px-8 font-serif text-lg leading-relaxed text-text/80 md:px-12 md:text-xl">
          <span
            class="pointer-events-none absolute -left-1 -top-3 font-serif text-5xl leading-none text-accent/60 md:-left-2 md:-top-4 md:text-6xl"
            aria-hidden="true"
          >
            “
          </span>

          Un site web n’est pas seulement une vitrine&nbsp;:
          <span class="text-primary">
            c’est la carte d’identité numérique de votre entreprise.
          </span>
          Bien conçu, il affirme votre image, rassure vos visiteurs et rend votre activité visible
          là où vos clients vous cherchent.
          <span class="font-semibold text-text">
            Design soigné, structure propre, référencement solide&nbsp;: pensé pour servir votre activité.
          </span>

          <span
            class="pointer-events-none absolute -right-1 -bottom-6 font-serif text-5xl leading-none text-accent/60 md:-right-2 md:-bottom-7 md:text-6xl"
            aria-hidden="true"
          >
            ”
          </span>
        </p>

        <span
          class="mx-auto block h-px w-24 bg-linear-to-r from-transparent via-primary/45 to-transparent"
          aria-hidden="true"
        ></span>
      </div>

      <!-- Services rapides -->
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {webCards.map((card) => (
          <article
            class="group relative overflow-hidden rounded-2xl border border-white/80 bg-white/45 p-5 shadow-[0_18px_45px_rgba(8,7,8,0.08)] backdrop-blur-xl transition duration-300 hover:border-accent/50 hover:bg-white/55 hover:shadow-[0_24px_60px_rgba(8,7,8,0.12)]"
          >
            <!-- Reflet liquid glass -->
            <div
              class="pointer-events-none absolute inset-0 rounded-2xl bg-linear-to-br from-white/80 via-white/20 to-primary/10 opacity-70"
              aria-hidden="true"
            ></div>

            <!-- Ligne brillante -->
            <div
              class="pointer-events-none absolute inset-x-4 top-0 h-px bg-linear-to-r from-transparent via-white/90 to-transparent"
              aria-hidden="true"
            ></div>

            <div class="relative z-10">
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/70 bg-white/45 text-primary shadow-sm backdrop-blur-md">
                <Icon name={card.icon} class="h-5 w-5" aria-hidden="true" />
              </div>

              <h3 class="mt-4 font-semibold text-text">
                {card.title}
              </h3>

              <p class="mt-2 text-sm leading-relaxed text-text/80">
                {card.desc}
              </p>
            </div>
          </article>
        ))}
      </div>

            <!-- Séparateur fin de section -->
      <div class="mx-auto mt-20 max-w-2xl" aria-hidden="true">
        <div class="flex items-center justify-center gap-4">
          <span class="h-px flex-1 bg-linear-to-r from-transparent via-primary/30 to-primary/10"></span>

          <div class="flex items-center gap-2 rounded-full border border-white/70 bg-white/45 px-4 py-2 text-primary shadow-sm backdrop-blur-xl">
            <Icon name="lucide:layout-template" class="h-4 w-4" />
            <span class="h-1 w-1 rounded-full bg-accent/70"></span>
            <Icon name="lucide:code-2" class="h-4 w-4" />
            <span class="h-1 w-1 rounded-full bg-accent/70"></span>
            <Icon name="lucide:rocket" class="h-4 w-4" />
          </div>

          <span class="h-px flex-1 bg-linear-to-l from-transparent via-primary/30 to-primary/10"></span>
        </div>
      </div>


    </div>
  </div>
</section>

<script define:vars={{ webProjects }}>
  const image = document.getElementById("web-showcase-image");
  const captionLink = document.getElementById("web-showcase-caption-link");
  const name = document.getElementById("web-showcase-name");
  const switchButton = document.getElementById("web-showcase-switch");
  const switchIcon = switchButton?.querySelector(".web-showcase-switch-icon");

  const fallbackProject = webProjects[0];

  const params = new URLSearchParams(window.location.search);
  const requestedProjectSlug = params.get("webProject");

  const requestedProjectIndex = webProjects.findIndex(
    (project) => project.slug === requestedProjectSlug
  );

  let currentIndex =
    requestedProjectIndex >= 0
      ? requestedProjectIndex
      : Math.floor(Math.random() * webProjects.length);

  const updateProject = (index) => {
    const project = webProjects[index];

    if (!image || !captionLink || !name) return;

    image.src = project.image;
    image.alt = project.alt;

    name.textContent = project.name;

    if (project.isCurrentSite) {
      captionLink.removeAttribute("href");
      captionLink.removeAttribute("aria-label");
      captionLink.setAttribute("aria-hidden", "true");
      captionLink.setAttribute("tabindex", "-1");

      captionLink.classList.add("invisible", "pointer-events-none");
    } else {
      captionLink.href = project.href;
      captionLink.setAttribute("aria-label", `Visiter le site ${project.name}`);
      captionLink.removeAttribute("aria-hidden");
      captionLink.removeAttribute("tabindex");

      captionLink.classList.remove("invisible", "pointer-events-none");
    }
  };

  image?.addEventListener("error", () => {
    if (!image || !captionLink || !name) return;

    image.src = fallbackProject.image;
    image.alt = fallbackProject.alt;

    name.textContent = fallbackProject.name;

    if (project.isCurrentSite) {
      captionLink.removeAttribute("href");
      captionLink.removeAttribute("aria-label");
      captionLink.setAttribute("aria-hidden", "true");
      captionLink.setAttribute("tabindex", "-1");

      captionLink.classList.add("invisible", "pointer-events-none");
    } else {
      captionLink.href = project.href;
      captionLink.setAttribute("aria-label", `Visiter le site ${project.name}`);
      captionLink.removeAttribute("aria-hidden");
      captionLink.removeAttribute("tabindex");

      captionLink.classList.remove("invisible", "pointer-events-none");
    }

    currentIndex = 0;
  });

  updateProject(currentIndex);

  switchButton?.addEventListener("click", () => {
    currentIndex = (currentIndex + 1) % webProjects.length;

    switchIcon?.classList.remove("animate-[webSwitchSpin_800ms_cubic-bezier(0.4,0,0.2,1)]");
    void switchIcon?.clientWidth;
    switchIcon?.classList.add("animate-[webSwitchSpin_800ms_cubic-bezier(0.4,0,0.2,1)]");

    updateProject(currentIndex);
  });
</script>

<style>
  @keyframes webSwitchSpin {
    0% {
      transform: rotate(0deg);
    }

    100% {
      transform: rotate(-360deg);
    }
  }
</style>
