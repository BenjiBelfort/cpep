---
// src/components/PackagingTeaserSection.astro
import { Icon } from "astro-icon/components";
import QuoteButton from "./ui/QuoteButton.astro";

const packagingCards = [
  {
    icon: "lucide:shopping-bag",
    title: "Choisir le bon sac",
    desc: "Poignées plates, torsadées, kraft brun, kraft blanc, format traiteur ou finition premium : nous vous aidons à choisir le support adapté à votre usage réel.",
  },
  {
    icon: "lucide:factory",
    title: "Fournisseurs proches & fiables",
    desc: "Nous privilégions des partenaires connus, principalement en France et en Europe, pour proposer des produits fiables, cohérents et bien sourcés.",
  },
  {
    icon: "lucide:clipboard-check",
    title: "Devis clair & suivi propre",
    desc: "Brief, formats, quantités, BAT, commande fournisseur et livraison : chaque étape est cadrée pour éviter les mauvaises surprises. Le fun, oui. Le flou, non.",
  },
];

---

<section id="print" aria-labelledby="pack-title" class="relative isolate scroll-m-4 overflow-x-clip">
  <div class="mx-auto px-4 py-20 cpep-radial">
    <div class="relative z-20 my-12 flex justify-center">
      <p class="inline-flex flex-col items-center gap-2 text-center text-sm font-medium uppercase tracking-[0.18em] text-primary sm:flex-row sm:text-left">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 sm:h-auto sm:w-auto sm:bg-transparent">
          <Icon
            name="lucide:shopping-bag"
            class="h-5 w-5 sm:h-4 sm:w-4"
            aria-hidden="true"
          />
        </span>

        <span>Sacs papier personnalisés & Print utile</span>
      </p>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="grid min-w-0 items-center gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
        <!-- Colonne texte -->
        <div class="contents min-w-0 lg:block">
          <h2
            id="pack-title"
            class="order-1 mt-6 min-w-0 text-left text-4xl font-bold text-text md:text-5xl lg:text-7xl lg:mt-6"
          >
            Des sacs personnalisés qui portent votre image.
          </h2>

          <div class="order-3 min-w-0 text-left lg:order-none">
            <p class="mt-6 max-w-3xl text-text/90">
              Depuis plus de 25 ans dans l’emballage, nous accompagnons les entreprises dans
              le choix de leurs <strong>sacs papier personnalisés</strong> : poignées plates,
              poignées torsadées, kraft brun, kraft blanc, formats traiteur, impression sobre
              ou finitions premium. L’objectif : trouver le bon sac, au bon prix, avec un
              rendu de qualité et un sourcing maîtrisé.
            </p>

            <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">

              <QuoteButton label="Votre projet sacs papier" />
              <!-- <QuoteButton label="Parler de mon projet sacs papier" href="/devis-packaging" /> -->
            </div>
          </div>
        </div>

        <!-- Image produit droite -->
        <div class="order-2 min-w-0 lg:order-none">
          <div class="relative mx-auto flex max-w-xl items-center justify-center lg:mx-0 lg:max-w-none lg:justify-end">
            <!-- Halo de mise en valeur -->
            <div
              class="pointer-events-none absolute -right-20 -top-10 h-72 w-72 rounded-full bg-primary/20 blur-3xl lg:-right-40 lg:-top-24 lg:h-96 lg:w-96"
              aria-hidden="true"
            ></div>

            <!-- Ombre posée -->
            <div
              class="pointer-events-none absolute bottom-2 left-1/2 h-10 w-[78%] -translate-x-1/2 rounded-full bg-black/15 blur-2xl lg:-right-20 lg:left-auto lg:w-[90%] lg:translate-x-0"
              aria-hidden="true"
            ></div>

            <!-- Image sans cadre, volontairement débordante -->
            <img
              src="/photos/sacs-ensemble.webp"
              alt="Ensemble de sacs papier personnalisés CPEP"
              width="900"
              height="900"
              loading="lazy"
              decoding="async"
              class="relative z-0 w-[115%] max-w-none -translate-y-6 translate-x-6 object-contain opacity-90 drop-shadow-2xl sm:w-[105%] lg:w-[135%] lg:-translate-y-20 lg:translate-x-32 xl:w-[150%] xl:-translate-y-28 xl:translate-x-44"
            />
          </div>
        </div>

      </div>

      <p class="font-serif mx-auto mt-12 max-w-3xl text-center leading-relaxed text-text/80">
        Un sac papier personnalisé n’est pas juste un contenant : c’est un support de
        communication qui circule avec votre marque. Nous vous aidons à choisir le format,
        la matière, les quantités et les finitions selon votre usage réel, votre image
        et votre budget. Pas de gadget, pas de survente : du concret.
      </p>

      <!-- Services rapides -->
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {packagingCards.map((card) => (
          <article
            class="group relative overflow-hidden rounded-2xl border border-white/80 bg-white/45 p-5 shadow-[0_18px_45px_rgba(8,7,8,0.08)] backdrop-blur-xl transition duration-300 hover:border-accent/50 hover:bg-white/55 hover:shadow-[0_24px_60px_rgba(8,7,8,0.12)]"
          >
            <!-- Reflet liquid glass -->
            <div
              class="pointer-events-none absolute inset-0 rounded-2xl bg-linear-to-br from-white/80 via-white/20 to-primary/10 opacity-70"
              aria-hidden="true"
            ></div>

            <!-- Ligne brillante -->
            <div
              class="pointer-events-none absolute inset-x-4 top-0 h-px bg-linear-to-r from-transparent via-white/90 to-transparent"
              aria-hidden="true"
            ></div>

            <div class="relative z-10">
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/70 bg-white/45 text-primary shadow-sm backdrop-blur-md">
                <Icon name={card.icon} class="h-5 w-5" aria-hidden="true" />
              </div>

              <h3 class="mt-4 font-semibold text-text">
                {card.title}
              </h3>

              <p class="mt-2 text-sm leading-relaxed text-text/80">
                {card.desc}
              </p>
            </div>
          </article>
        ))}
      </div>
      </div>


    </div>
  </div>
</section>