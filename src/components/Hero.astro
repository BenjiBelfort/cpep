---
// src/components/Hero.astro
import QuoteButton from "./ui/QuoteButton.astro";
---

<section
  id="hero"
  class="relative isolate min-h-[100svh]"
  aria-labelledby="hero-title"
>
  <picture>
    <source srcset="/photos/hero-bag-mobile.webp" media="(max-width: 767px)" />
    <source srcset="/photos/hero-bag.webp" media="(min-width: 768px)" />
    <img
      src="/photos/hero-bag.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="mx-auto grid min-h-[100svh] max-w-6xl items-center gap-8 px-4 py-16 md:grid-cols-[1.1fr,1fr] md:py-24">
    <div class="max-w-[56ch] justify-self-start md:max-w-[52ch]">
      <h1 id="hero-title" class="text-left font-sans text-4xl font-medium text-text md:text-6xl">
        Sacs papier <strong>personnalisés</strong>, <strong>print</strong> et
        <strong>sites web</strong> sur mesure !
      </h1>

      <h2 class="mt-4 pr-8 text-left font-serif text-lg text-text md:pr-0">
        Vos outils de <strong>communication</strong> visuelle pour la mise en valeur de votre <strong>identité</strong>
      </h2>

      <div
        class="mt-6 flex flex-col items-start gap-3 sm:flex-row sm:flex-wrap sm:gap-4"
        role="group"
        aria-label="Accès rapide"
      >
        <QuoteButton
          variant="primary"
          label="Print"
          icon="lucide:shopping-bag"
          href="#print"
        />

        <QuoteButton
          variant="primary"
          label="Web"
          icon="lucide:code-2"
          href="#web"
        />
      </div>
    </div>

    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-bg/100 via-bg/30 to-transparent md:hidden"></div>

    <div class="hidden md:block"></div>
  </div>
</section>