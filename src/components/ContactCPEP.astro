---
// src/components/ContactCPEP.astro
import { Icon } from 'astro-icon/components';

const contactItems = [
  {
    icon: 'lucide:mail',
    title: 'Email',
    content: 'contact@cpep.fr',
    href: 'mailto:contact@cpep.fr',
  },
  {
    icon: 'lucide:phone',
    title: 'Téléphone',
    content: '+33 6 13 99 12 31',
    href: 'tel:+33613991231',
  },
  {
    icon: 'lucide:map-pin',
    title: 'Zone',
    content: 'France & Europe',
    description: 'Partenaires proches, délais et qualité maîtrisés.',
  },
];

const fieldClasses =
  'mt-1 w-full rounded-xl border border-white/80 bg-white/80 px-3 py-2.5 text-text shadow-sm outline-none transition placeholder:text-text/40 focus:border-accent focus:bg-white focus:ring-2 focus:ring-accent/25';

const cardClasses =
  'relative rounded-2xl border border-white/70 bg-white/80 p-6 shadow-[0_18px_45px_rgba(8,7,8,0.12)]';
---

<!-- Modal feedback contact -->
<div
  id="contact-feedback"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-primary-900/45 px-4 backdrop-blur-md"
  aria-live="polite"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-feedback-title"
>
  <div
    class="relative max-h-[calc(100vh-2rem)] w-full max-w-md overflow-y-auto rounded-3xl border border-white/70 bg-white/90 p-6 text-center text-text shadow-[0_24px_80px_rgba(8,7,8,0.28)]"
  >
    <div class="relative">
      <!-- Icône succès -->
      <div
        data-contact-ok-icon
        class="mx-auto hidden h-16 w-16 items-center justify-center rounded-full border border-success/25 bg-success/10 text-success shadow-sm"
      >
        <Icon name="lucide:check" class="h-9 w-9" aria-hidden="true" />
      </div>

      <!-- Icône erreur -->
      <div
        data-contact-error-icon
        class="mx-auto hidden h-16 w-16 items-center justify-center rounded-full border border-error/25 bg-error/10 text-error shadow-sm"
      >
        <Icon name="lucide:triangle-alert" class="h-9 w-9" aria-hidden="true" />
      </div>

      <h3
        id="contact-feedback-title"
        data-contact-title
        class="mt-5 text-2xl font-bold text-text"
      >
        Message envoyé
      </h3>

      <p data-contact-ok class="mt-3 hidden text-sm leading-relaxed text-text/75">
        Merci, votre message a bien été envoyé. Nous revenons vers vous rapidement
        avec une réponse claire et utile.
      </p>

      <p data-contact-error class="mt-3 hidden text-sm leading-relaxed text-text/75">
        Le message n’a pas pu être envoyé. Vous pouvez réessayer dans un instant ou nous écrire directement à
        <a
          href="mailto:contact@cpep.fr"
          class="font-medium text-primary underline decoration-accent underline-offset-4"
        >
          contact@cpep.fr
        </a>.
      </p>

      <div class="mt-6 h-1.5 overflow-hidden rounded-full bg-text/10">
        <div
          data-contact-progress
          class="h-full w-0 rounded-full bg-success transition-all duration-1000 ease-out"
        ></div>
      </div>

      <button
        type="button"
        data-contact-close
        class="mt-6 inline-flex cursor-pointer items-center justify-center rounded-full border border-primary/30 bg-primary px-5 py-2.5 text-sm font-medium text-bg transition hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        Fermer
      </button>
    </div>
  </div>
</div>

<section
  id="contact"
  aria-labelledby="contact-title"
  class="relative scroll-m-4 cpep-contact-blueprint"
>
  <!-- Image décorative blueprint gauche -->
  <div
    class="pointer-events-none absolute left-[-18rem] top-[40%] -z-10 hidden aspect-square w-[clamp(34rem,52vw,58rem)] -translate-y-1/2 -rotate-6 opacity-20 mix-blend-screen lg:block"
    aria-hidden="true"
  >
    <img
      src="/photos/fonds/computer-blue-print.webp"
      alt=""
      loading="lazy"
      class="h-full w-full object-contain"
    />
  </div>

  <!-- Image décorative blueprint droite -->
  <div
    class="pointer-events-none absolute right-[-14rem] top-[8%] -z-10 aspect-square w-[clamp(26rem,88vw,58rem)] rotate-6 opacity-16 mix-blend-screen lg:right-[-18rem] lg:top-1/2 lg:w-[clamp(34rem,52vw,58rem)] lg:-translate-y-1/2 lg:opacity-20"
    aria-hidden="true"
  >
    <img
      src="/photos/fonds/sac-blue-print-r.webp"
      alt=""
      loading="lazy"
      class="h-full w-full object-contain"
    />
  </div>

  <div class="mx-auto max-w-6xl px-4 py-20">
    <div class="my-12 flex justify-center">
      <p class="inline-flex flex-col items-center gap-2 text-center text-sm font-medium uppercase tracking-[0.18em] text-white/85 sm:flex-row sm:text-left">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 sm:h-auto sm:w-auto sm:bg-transparent">
          <Icon name="lucide:message-circle" class="h-5 w-5 sm:h-4 sm:w-4" aria-hidden="true" />
        </span>

        <span>Discutons de votre projet</span>
      </p>
    </div>

    <header class="mx-auto max-w-3xl text-center">
      <h2
        id="contact-title"
        class="text-4xl font-bold text-white md:text-6xl"
      >
        Un besoin, une idée, un projet ?
      </h2>

      <p class="mx-auto mt-5 max-w-2xl text-white/80">
        Parlez-nous de votre projet web, print, packaging ou objet personnalisé.
        Nous revenons vers vous avec une réponse claire, généralement sous
        <strong>24 à 48 h</strong>.
      </p>
    </header>

    <div class="mt-12 grid items-start gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <!-- Infos -->
      <aside class={cardClasses}>

        <div>
          <h3 class="text-xl font-semibold text-text">
            Coordonnées
          </h3>

          <p class="mt-3 text-sm leading-relaxed text-text/75">
            Décrivez-nous votre besoin, même si le projet n’est pas encore totalement cadré.
            Nous vous aidons à préciser les bonnes options, les contraintes utiles et les prochaines étapes.
          </p>

          <ul class="mt-6 space-y-4">
            {contactItems.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/70 bg-white/45 text-primary shadow-sm backdrop-blur-md">
                  <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
                </span>

                <div>
                  <p class="font-semibold text-text">{item.title}</p>

                  {item.href ? (
                    <a
                      href={item.href}
                      class="text-sm text-text underline decoration-accent underline-offset-4 transition hover:text-accent"
                    >
                      {item.content}
                    </a>
                  ) : (
                    <p class="text-sm text-text">{item.content}</p>
                  )}

                  {item.description && (
                    <p class="mt-1 text-sm leading-relaxed text-text/70">
                      {item.description}
                    </p>
                  )}
                </div>
              </li>
            ))}
          </ul>

          <div class="mt-7 overflow-hidden rounded-2xl border border-white/70 bg-white/45 p-5 text-sm text-text shadow-sm backdrop-blur-md">
            <div class="flex items-center gap-2 font-semibold">
              <Icon name="lucide:lightbulb" class="h-4 w-4 text-primary" aria-hidden="true" />
              <p>Pour un devis plus précis</p>
            </div>

            <p class="mt-3 leading-relaxed text-text/80">
              Indiquez les <strong>quantités</strong>, <strong>formats</strong>,
              <strong> matières</strong>, <strong>finitions</strong> ou les
              <strong> fonctionnalités web</strong> souhaitées.
            </p>

            <p class="mt-2 leading-relaxed text-text/80">
              Plus le brief est clair, plus la réponse est juste et adaptée à votre besoin.
            </p>
          </div>
        </div>
      </aside>

      <!-- Formulaire -->
      <form
        id="contact-form"
        action="/api/contact.php"
        method="POST"
        accept-charset="UTF-8"
        class={cardClasses}
      >

      <!-- Honeypot -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />

      <!-- Temps de remplissage -->
      <input
        type="hidden"
        name="started_at"
        id="contact-started-at"
      />
        <div class="grid gap-4 md:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-text">
              Votre nom <span class="text-accent">*</span>
            </span>

            <input
              name="name"
              required
              autocomplete="name"
              class={fieldClasses}
            />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-text">
              Email <span class="text-accent">*</span>
            </span>

            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class={fieldClasses}
            />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-text">Téléphone</span>

            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              class={fieldClasses}
            />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-text">Société / structure</span>

            <input
              name="company"
              autocomplete="organization"
              class={fieldClasses}
            />
          </label>

          <label class="block md:col-span-2">
            <span class="text-sm font-medium text-text">
              Votre message <span class="text-accent">*</span>
            </span>

            <textarea
              name="message"
              required
              rows={7}
              placeholder="Expliquez votre besoin, vos quantités, vos délais, vos contraintes ou votre idée encore en chantier..."
              class={`${fieldClasses} resize-y`}
            ></textarea>
          </label>

          <label class="flex items-start gap-3 rounded-xl border border-white/70 bg-white/45 p-4 shadow-sm backdrop-blur-md md:col-span-2">
            <input
              type="checkbox"
              name="consent"
              required
              class="consent-checkbox mt-1 h-4 w-4 rounded border-bg-alt"
            />

            <span class="text-sm leading-relaxed text-text/80">
              J’accepte que mes données soient utilisées pour répondre à ma demande.
              Pas de newsletter cachée, pas de spam, pas de pigeon voyageur douteux.
            </span>
          </label>

          <div class="md:col-span-2">
            <button
              type="submit"
              class="group inline-flex min-h-10 cursor-pointer items-center justify-center gap-2 rounded-full border border-primary/30 bg-primary px-4 py-2 font-medium text-bg backdrop-blur-md transition hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent sm:min-h-12 sm:px-6 sm:py-3"
            >
              <Icon
                name="lucide:send"
                class="h-4 w-4 shrink-0"
                aria-hidden="true"
              />

              <span class="text-sm md:text-base">
                Envoyer ma demande
              </span>

              <Icon
                name="lucide:arrow-right"
                class="h-4 w-4 shrink-0 opacity-100 transition duration-300 sm:opacity-0 sm:group-hover:translate-x-1 sm:group-hover:opacity-100"
                aria-hidden="true"
              />
            </button>

            <p class="mt-3 text-xs leading-relaxed text-text/60">
              Les informations transmises servent uniquement à traiter votre demande.
              Elles ne sont pas revendues à des tiers.
            </p>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  const contactForm = document.querySelector("#contact-form");
  const startedAtInput = document.querySelector("#contact-started-at");
  const feedback = document.querySelector("#contact-feedback");
  const feedbackTitle = document.querySelector("[data-contact-title]");
  const successMessage = document.querySelector("[data-contact-ok]");
  const errorMessage = document.querySelector("[data-contact-error]");
  const successIcon = document.querySelector("[data-contact-ok-icon]");
  const errorIcon = document.querySelector("[data-contact-error-icon]");
  const progressBar = document.querySelector("[data-contact-progress]");
  const closeButton = document.querySelector("[data-contact-close]");

  if (startedAtInput) {
    startedAtInput.value = String(Date.now());
  }

  const closeFeedback = () => {
    if (!feedback) return;

    feedback.classList.add("hidden");
    feedback.classList.remove("flex");

    if (progressBar) {
      progressBar.classList.remove("w-full", "bg-success", "bg-error");
      progressBar.classList.add("w-0");
    }
  };

  const showFeedback = (type) => {
    if (
      !feedback ||
      !feedbackTitle ||
      !successMessage ||
      !errorMessage ||
      !successIcon ||
      !errorIcon ||
      !progressBar
    ) {
      return;
    }

    feedback.classList.remove("hidden");
    feedback.classList.add("flex");

    successMessage.classList.add("hidden");
    errorMessage.classList.add("hidden");

    successIcon.classList.add("hidden");
    successIcon.classList.remove("flex");

    errorIcon.classList.add("hidden");
    errorIcon.classList.remove("flex");

    progressBar.classList.remove("w-full", "bg-success", "bg-error");
    progressBar.classList.add("w-0");

    feedbackTitle.classList.remove("text-success", "text-error");
    feedbackTitle.classList.add("text-text");

    if (type === "ok") {
      feedbackTitle.textContent = "Message envoyé";
      feedbackTitle.classList.remove("text-text");
      feedbackTitle.classList.add("text-success");

      successMessage.classList.remove("hidden");
      successIcon.classList.remove("hidden");
      successIcon.classList.add("flex");

      progressBar.classList.add("bg-success");
    } else {
      feedbackTitle.textContent = "Envoi impossible";
      feedbackTitle.classList.remove("text-text");
      feedbackTitle.classList.add("text-error");

      errorMessage.classList.remove("hidden");
      errorIcon.classList.remove("hidden");
      errorIcon.classList.add("flex");

      progressBar.classList.add("bg-error");
    }

    window.setTimeout(() => {
      progressBar.classList.remove("w-0");
      progressBar.classList.add("w-full");
    }, 80);
  };

  closeButton?.addEventListener("click", closeFeedback);

  feedback?.addEventListener("click", (event) => {
    if (event.target === feedback) {
      closeFeedback();
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeFeedback();
    }
  });

  if (contactForm) {
    contactForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const submitButton = contactForm.querySelector('button[type="submit"]');
      const formData = new FormData(contactForm);

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.classList.add("opacity-70", "cursor-not-allowed");
        submitButton.classList.remove("cursor-pointer");
      }

      try {
        const response = await fetch(contactForm.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          showFeedback("error");
          return;
        }

        contactForm.reset();

        if (startedAtInput) {
          startedAtInput.value = String(Date.now());
        }

        showFeedback("ok");
      } catch (error) {
          console.error("Erreur formulaire contact :", error);
          showFeedback("error");
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.classList.remove("opacity-70", "cursor-not-allowed");
          submitButton.classList.add("cursor-pointer");
        }
      }
    });
  }
</script>