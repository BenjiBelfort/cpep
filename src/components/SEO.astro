---
// src/components/SEO.astro
import { site as SITE } from "../config/site";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: unknown | unknown[];
}

const {
  title,
  description,
  image = SITE.seo.defaultImage,
  type = "website",
  noindex = false,
} = (Astro.props || {}) as Props;

const pathname = Astro.url?.pathname || "/";
const isHome = pathname === "/";

const canonical = Astro.site ? new URL(pathname, Astro.site).toString() : undefined;

const pageTitle = (() => {
  if (title && title.trim()) {
    return isHome ? title.trim() : `${title.trim()} — ${SITE.name}`;
  }

  return SITE.seo.defaultTitle;
})();

const pageDesc =
  description && description.trim()
    ? description.trim()
    : SITE.seo.defaultDescription;

const ogImageAbs = Astro.site ? new URL(image, Astro.site).toString() : image;
---

<title>{pageTitle}</title>

<meta name="description" content={pageDesc} />

{noindex && <meta name="robots" content="noindex, nofollow" />}

{canonical && <link rel="canonical" href={canonical} />}
{canonical && <link rel="alternate" href={canonical} hreflang="fr-FR" />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:image" content={ogImageAbs} />
<meta property="og:locale" content="fr_FR" />
<meta property="og:image:alt" content={SITE.seo.ogImageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image" content={ogImageAbs} />
<meta name="twitter:image:alt" content={SITE.seo.ogImageAlt} />